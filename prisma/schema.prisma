// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(cuid())
  clerkId         String        @unique
  email           String        @unique
  firstName       String?
  lastName        String?
  role            UserRole
  trades          JobCategory[] // For tradespeople - selected trade categories
  stripeAccountId String? // Stripe Connect account ID for tradespeople
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relationships
  jobsPosted       Job[]           @relation("CustomerJobs")
  applications     Application[]
  messagesSent     Message[]       @relation("MessageSender")
  messagesReceived Message[]       @relation("MessageReceiver")
  quoteTemplates   QuoteTemplate[]

  @@map("users")
}

model Job {
  id                            String      @id @default(cuid())
  title                         String
  description                   String
  category                      JobCategory
  location                      String // Legacy text field for display
  latitude                      Float? // For distance-based searches
  longitude                     Float? // For distance-based searches
  formattedAddress              String? // Full address from Google Places
  city                          String? // Extracted city/town
  postcode                      String? // UK postcode for filtering
  budget                        Decimal?
  status                        JobStatus   @default(OPEN)
  attachments                   String? // Store as JSON string of file URLs
  customerId                    String
  depositPaid                   Boolean     @default(false)
  depositPaymentIntentId        String?     @unique // Ensure each payment intent is used only once
  finalPaid                     Boolean     @default(false)
  finalPaymentIntentId          String?     @unique // Ensure each payment intent is used only once
  acceptedTradespersonId        String?
  customerConfirmedComplete     Boolean     @default(false)
  tradespersonConfirmedComplete Boolean     @default(false)
  customerCompletedAt           DateTime?
  tradespersonCompletedAt       DateTime?
  payoutReleased                Boolean     @default(false)
  payoutTransferId              String?
  createdAt                     DateTime    @default(now())
  updatedAt                     DateTime    @updatedAt

  // Relationships
  customer     User          @relation("CustomerJobs", fields: [customerId], references: [id], onDelete: Cascade)
  applications Application[]
  messages     Message[]

  @@index([customerId])
  @@index([status, category])
  @@index([createdAt])
  @@index([postcode]) // For postcode-based searches
  @@index([city]) // For city-based searches
  @@index([latitude, longitude]) // For distance-based queries
  @@map("jobs")
}

model Application {
  id                String            @id @default(cuid())
  message           String
  quote             Decimal?
  quoteItems        Json?
  requiresDeposit   Boolean           @default(true)
  depositPercentage Int               @default(50)
  status            ApplicationStatus @default(PENDING)
  jobId             String
  tradespersonId    String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relationships
  job          Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tradesperson User @relation(fields: [tradespersonId], references: [id], onDelete: Cascade)

  @@unique([jobId, tradespersonId])
  @@index([tradespersonId])
  @@index([jobId, status])
  @@map("applications")
}

model Message {
  id          String      @id @default(cuid())
  content     String
  senderId    String
  receiverId  String
  jobId       String?
  messageType MessageType @default(TEXT)
  createdAt   DateTime    @default(now())

  // Relationships
  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  job      Job? @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, senderId, receiverId])
  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@map("messages")
}

model QuoteTemplate {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items QuoteTemplateItem[]
}

model QuoteTemplateItem {
  id          String   @id @default(cuid())
  templateId  String
  description String
  price       Decimal
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template QuoteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model WebhookEvent {
  id        String   @id // Stripe event ID
  processed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([id, processed])
  @@map("webhook_events")
}

model Ticket {
  id             String         @id @default(cuid())
  createdAt      DateTime       @default(now())
  lastUpdatedAt  DateTime       @updatedAt
  createdById    String
  createdByEmail String
  role           TicketRole
  category       String
  priority       TicketPriority @default(NORMAL)
  subject        String
  initialBody    String
  status         TicketStatus   @default(OPEN)
  assigneeId     String?
  messages       TicketMessage[]

  @@index([createdById])
  @@index([status])
  @@index([assigneeId])
  @@index([createdAt])
  @@map("tickets")
}

model TicketMessage {
  id          String              @id @default(cuid())
  createdAt   DateTime            @default(now())
  ticketId    String
  authorId    String
  authorRole  String // "user" | "admin"
  body        String
  attachments TicketAttachment[]
  ticket      Ticket              @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([authorId])
  @@map("ticket_messages")
}

model TicketAttachment {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  messageId   String
  fileKey     String
  fileName    String
  bytes       Int
  contentType String
  message     TicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("ticket_attachments")
}

// Enums
enum UserRole {
  CUSTOMER
  TRADESPERSON
}

enum JobCategory {
  PLUMBING
  ELECTRICAL
  CARPENTRY
  BRICKLAYING
  PLASTERING
  PAINTING
  LANDSCAPING
  CLEANING
  HANDYMAN
  OTHER
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketRole {
  CUSTOMER
  TRADESPERSON
}
