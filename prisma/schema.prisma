// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(cuid())
  clerkId         String        @unique
  email           String        @unique
  firstName       String?
  lastName        String?
  role            UserRole      @default(PENDING)
  trades          JobCategory[] // For tradespeople - selected trade categories
  stripeAccountId String? // Stripe Connect account ID for tradespeople
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relationships
  jobsPosted       Job[]              @relation("CustomerJobs")
  applications     Application[]
  messagesSent     Message[]          @relation("MessageSender")
  messagesReceived Message[]          @relation("MessageReceiver")
  quoteTemplates   QuoteTemplate[]
  emailPreference  EmailPreference?
  emailSuppressions EmailSuppression[]

  @@map("users")
}

model Job {
  id                            String       @id @default(cuid())
  title                         String
  description                   String
  category                      JobCategory
  location                      String // Legacy text field for display
  placeId                       String? // Google Places ID for validation and future verification
  latitude                      Float? // For distance-based searches
  longitude                     Float? // For distance-based searches
  formattedAddress              String? // Full address from Google Places
  city                          String? // Extracted city/town
  postcode                      String? // UK postcode for filtering
  budget                        Decimal?
  status                        JobStatus    @default(OPEN)
  attachments                   String? // Store as JSON string of file URLs
  customerId                    String
  depositPaid                   Boolean      @default(false)
  depositPaymentIntentId        String?      @unique // Ensure each payment intent is used only once
  finalPaid                     Boolean      @default(false)
  finalPaymentIntentId          String?      @unique // Ensure each payment intent is used only once
  acceptedTradespersonId        String?
  customerConfirmedComplete     Boolean      @default(false)
  tradespersonConfirmedComplete Boolean      @default(false)
  customerCompletedAt           DateTime?
  tradespersonCompletedAt       DateTime?
  payoutReleased                Boolean      @default(false)
  payoutTransferId              String? // Legacy field, migrated to depositTransferId
  
  // Payment tracking fields
  transferGroup                 String? // "job_${jobId}" for linking payments
  depositChargeId               String? // Stripe Charge ID for deposit
  depositTransferId             String? // Stripe Transfer ID for deposit
  depositReleasedAt             DateTime? // When deposit transfer was created
  finalChargeId                 String? // Stripe Charge ID for final payment
  finalTransferId               String? // Stripe Transfer ID for final payment
  finalReleasedAt               DateTime? // When final transfer was created
  chargeModel                   ChargeModel? @default(DESTINATION_CHARGE) // Track which charge model is used
  
  createdAt                     DateTime     @default(now())
  updatedAt                     DateTime     @updatedAt

  // Relationships
  customer     User          @relation("CustomerJobs", fields: [customerId], references: [id], onDelete: Cascade)
  applications Application[]
  messages     Message[]

  @@index([customerId])
  @@index([status, category])
  @@index([createdAt])
  @@index([postcode]) // For postcode-based searches
  @@index([city]) // For city-based searches
  @@index([latitude, longitude]) // For distance-based queries
  @@map("jobs")
}

model Application {
  id                String            @id @default(cuid())
  message           String
  quote             Decimal?
  quoteItems        Json?
  requiresDeposit   Boolean           @default(true)
  depositPercentage Int               @default(50)
  status            ApplicationStatus @default(PENDING)
  jobId             String
  tradespersonId    String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relationships
  job          Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tradesperson User @relation(fields: [tradespersonId], references: [id], onDelete: Cascade)

  @@unique([jobId, tradespersonId])
  @@index([tradespersonId])
  @@index([jobId, status])
  @@map("applications")
}

model Message {
  id          String      @id @default(cuid())
  content     String
  senderId    String
  receiverId  String
  jobId       String?
  messageType MessageType @default(TEXT)
  createdAt   DateTime    @default(now())

  // Relationships
  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  job      Job? @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, senderId, receiverId])
  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@map("messages")
}

model QuoteTemplate {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items QuoteTemplateItem[]
}

model QuoteTemplateItem {
  id          String   @id @default(cuid())
  templateId  String
  description String
  price       Decimal
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template QuoteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model WebhookEvent {
  id        String   @id // Stripe event ID
  processed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([id, processed])
  @@map("webhook_events")
}

// Enums
enum UserRole {
  PENDING // User has not completed onboarding
  CUSTOMER
  TRADESPERSON
}

enum JobCategory {
  PLUMBING
  ELECTRICAL
  CARPENTRY
  BRICKLAYING
  PLASTERING
  PAINTING
  LANDSCAPING
  CLEANING
  HANDYMAN
  OTHER
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

enum ChargeModel {
  DESTINATION_CHARGE // Current: instant transfer via transfer_data
  SC_AND_T          // Future: separate charges & transfers with control
}

// Email event tracking for idempotency and audit trail
model EmailEvent {
  id              String   @id @default(cuid())
  idempotencyKey  String   @unique // SHA-256 hash of event_type + payload
  eventType       String   // e.g., "UserRegistered", "JobResponded"
  payloadHash     String   // Hash of the full payload for verification
  status          EmailEventStatus @default(PENDING)
  messageId       String?  // Resend message ID after successful send
  recipientEmail  String
  subject         String?
  errorMessage    String?
  createdAt       DateTime @default(now())
  sentAt          DateTime?
  
  @@index([idempotencyKey])
  @@index([eventType, createdAt])
  @@index([recipientEmail, createdAt])
  @@map("email_events")
}

// User email preferences for transactional and digest emails
model EmailPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  allowTransactional    Boolean  @default(true) // Always true, locked for transactional
  allowDigest           Boolean  @default(true)
  digestFrequency       DigestFrequency @default(WEEKLY)
  professionFilters     JobCategory[] // Filter digest by these professions
  regionFilters         String[] // Array of postcodes or cities
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("email_preferences")
}

// Email suppressions for bounces, complaints, and manual unsubscribes
model EmailSuppression {
  id        String              @id @default(cuid())
  userId    String?
  email     String
  reason    SuppressionReason
  source    String?             // e.g., "resend_webhook", "manual"
  createdAt DateTime            @default(now())
  
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([email, reason])
  @@index([email])
  @@map("email_suppressions")
}

// Email event status enum
enum EmailEventStatus {
  PENDING
  SENT
  FAILED
  SUPPRESSED
}

// Digest frequency options
enum DigestFrequency {
  DAILY
  WEEKLY
  NEVER
}

// Email suppression reasons
enum SuppressionReason {
  BOUNCE
  COMPLAINT
  MANUAL_UNSUBSCRIBE
  ABUSE
}
