// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(cuid())
  clerkId         String        @unique
  email           String        @unique
  firstName       String?
  lastName        String?
  role            UserRole      @default(PENDING)
  trades          JobCategory[] // For tradespeople - selected trade categories
  stripeAccountId String? // Stripe Connect account ID for tradespeople
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relationships
  jobsPosted       Job[]           @relation("CustomerJobs")
  applications     Application[]
  messagesSent     Message[]       @relation("MessageSender")
  messagesReceived Message[]       @relation("MessageReceiver")
  quoteTemplates   QuoteTemplate[]
  provider         Provider? // One-to-one relationship with Provider profile

  @@map("users")
}

model Job {
  id                            String      @id @default(cuid())
  title                         String
  description                   String
  category                      JobCategory
  location                      String // Legacy text field for display
  placeId                       String? // Google Places ID for validation and future verification
  latitude                      Float? // For distance-based searches
  longitude                     Float? // For distance-based searches
  formattedAddress              String? // Full address from Google Places
  city                          String? // Extracted city/town
  postcode                      String? // UK postcode for filtering
  budget                        Decimal?
  status                        JobStatus   @default(OPEN)
  attachments                   String? // Store as JSON string of file URLs
  customerId                    String
  depositPaid                   Boolean     @default(false)
  depositPaymentIntentId        String?     @unique // Ensure each payment intent is used only once
  finalPaid                     Boolean     @default(false)
  finalPaymentIntentId          String?     @unique // Ensure each payment intent is used only once
  acceptedTradespersonId        String?
  customerConfirmedComplete     Boolean     @default(false)
  tradespersonConfirmedComplete Boolean     @default(false)
  customerCompletedAt           DateTime?
  tradespersonCompletedAt       DateTime?
  payoutReleased                Boolean     @default(false)
  payoutTransferId              String?
  createdAt                     DateTime    @default(now())
  updatedAt                     DateTime    @updatedAt

  // Relationships
  customer     User          @relation("CustomerJobs", fields: [customerId], references: [id], onDelete: Cascade)
  applications Application[]
  messages     Message[]

  @@index([customerId])
  @@index([status, category])
  @@index([createdAt])
  @@index([postcode]) // For postcode-based searches
  @@index([city]) // For city-based searches
  @@index([latitude, longitude]) // For distance-based queries
  @@map("jobs")
}

model Application {
  id                String            @id @default(cuid())
  message           String
  quote             Decimal?
  quoteItems        Json?
  requiresDeposit   Boolean           @default(true)
  depositPercentage Int               @default(50)
  status            ApplicationStatus @default(PENDING)
  jobId             String
  tradespersonId    String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relationships
  job          Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tradesperson User @relation(fields: [tradespersonId], references: [id], onDelete: Cascade)

  @@unique([jobId, tradespersonId])
  @@index([tradespersonId])
  @@index([jobId, status])
  @@map("applications")
}

model Message {
  id          String      @id @default(cuid())
  content     String
  senderId    String
  receiverId  String
  jobId       String?
  messageType MessageType @default(TEXT)
  createdAt   DateTime    @default(now())

  // Relationships
  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  job      Job? @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, senderId, receiverId])
  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@map("messages")
}

model QuoteTemplate {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items QuoteTemplateItem[]
}

model QuoteTemplateItem {
  id          String   @id @default(cuid())
  templateId  String
  description String
  price       Decimal
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template QuoteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model WebhookEvent {
  id        String   @id // Stripe event ID
  processed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([id, processed])
  @@map("webhook_events")
}

model Provider {
  id                String        @id @default(cuid())
  slug              String        @unique // URL-friendly identifier
  businessName      String
  description       String?
  userId            String        @unique // Link to User (tradesperson)
  trades            JobCategory[] // Services offered
  isPublished       Boolean       @default(false) // Publication gate
  // NAP (Name, Address, Phone)
  address           String?
  addressLocality   String? // City/town
  addressRegion     String? // County/region
  postalCode        String?
  latitude          Float?
  longitude         Float?
  telephone         String?
  email             String?
  website           String?
  // Service areas
  serviceAreas      String[] // Array of cities/regions served
  // Accreditations
  accreditations    String[] // e.g., ["Gas Safe", "NICEIC"]
  gaseSafeNumber    String?
  niceicNumber      String?
  // Profile media
  logo              String?
  coverImage        String?
  // Reviews aggregation
  averageRating     Decimal? // Calculated field
  reviewCount       Int       @default(0)
  // Activity tracking
  responseTimeHours Int?      @default(24) // Average response time in hours
  jobsCompleted     Int       @default(0) // Total jobs completed
  lastActive        DateTime? // Last activity timestamp
  // Metadata
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews ProviderReview[]

  @@index([slug])
  @@index([isPublished])
  @@index([addressLocality, trades])
  @@index([lastActive])
  @@map("providers")
}

model ProviderReview {
  id             String   @id @default(cuid())
  providerId     String
  customerName   String // Anonymous or real name
  rating         Int // 1-5 stars
  reviewText     String?
  jobCompleted   DateTime? // When the job was completed
  isVerified     Boolean  @default(false) // Verified purchase/job
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, isPublished])
  @@index([rating])
  @@map("provider_reviews")
}

model LocalRule {
  id          String      @id @default(cuid())
  trade       JobCategory
  location    String // City, region, or "UK" for national
  ruleType    String // "license", "regulation", "safety", "waste"
  title       String
  description String // Free-text description
  reference   String? // Link to official guidance
  isActive    Boolean     @default(true)
  priority    Int         @default(0) // Higher priority shown first
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([trade, location, isActive])
  @@index([ruleType])
  @@map("local_rules")
}

// Enums
enum UserRole {
  PENDING // User has not completed onboarding
  CUSTOMER
  TRADESPERSON
}

enum JobCategory {
  PLUMBING
  ELECTRICAL
  CARPENTRY
  BRICKLAYING
  PLASTERING
  PAINTING
  LANDSCAPING
  CLEANING
  HANDYMAN
  OTHER
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}
