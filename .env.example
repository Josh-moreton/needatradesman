# Database
DATABASE_URL="postgresql://user:password@localhost:5432/needatradesman"

# Auth.js v5 Authentication
AUTH_SECRET=change_me_to_random_secret_32_chars_min
NEXTAUTH_URL=http://localhost:3000

# Email Provider (for magic links)
# Optional: Configure SMTP server for email magic links
# EMAIL_SERVER=smtp://user:pass@smtp.yourhost:587
# EMAIL_FROM=Need A Tradesman <auth@needatradesman.co.uk>

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true

# Redis (optional - for caching and rate limiting)
REDIS_URL=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Pusher (for real-time chat/notifications)
NEXT_PUBLIC_PUSHER_KEY=
PUSHER_APP_ID=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Google Maps (for location services)
# Get your API key from: https://console.cloud.google.com/
# Enable: Places API and Maps JavaScript API
# See docs/LOCATION_SERVICES.md for setup instructions
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Attachment Security
# Comma-separated list of allowed domains for job attachments
# If not set, defaults to: s3.amazonaws.com,cloudfront.net,r2.cloudflarestorage.com,storage.googleapis.com
# Example: NEXT_PUBLIC_ALLOWED_ATTACHMENT_DOMAINS=mybucket.s3.amazonaws.com,mycdn.cloudfront.net
NEXT_PUBLIC_ALLOWED_ATTACHMENT_DOMAINS=

# Crisp Chat (for customer support)
# Get your Website ID from: https://app.crisp.chat/ > Settings > Setup
NEXT_PUBLIC_CRISP_WEBSITE_ID=
