# Database
DATABASE_URL="postgresql://user:password@localhost:5432/needatradesman"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Updated to use new Clerk redirect props (fallback instead of after)
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Redis (optional - for caching and rate limiting)
REDIS_URL=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Pusher (for real-time chat/notifications)
NEXT_PUBLIC_PUSHER_KEY=
PUSHER_APP_ID=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Google Maps (for location services)
# Get your API key from: https://console.cloud.google.com/
# Enable: Places API and Maps JavaScript API
# See docs/LOCATION_SERVICES.md for setup instructions
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Attachment Security
# Comma-separated list of allowed domains for job attachments
# If not set, defaults to: s3.amazonaws.com,cloudfront.net,r2.cloudflarestorage.com,storage.googleapis.com
# Example: NEXT_PUBLIC_ALLOWED_ATTACHMENT_DOMAINS=mybucket.s3.amazonaws.com,mycdn.cloudfront.net
NEXT_PUBLIC_ALLOWED_ATTACHMENT_DOMAINS=

# Crisp Chat (for customer support)
# Get your Website ID from: https://app.crisp.chat/ > Settings > Setup
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Resend Email Service
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM="Need A Tradesman <noreply@needatradesman.co.uk>"
SUPPORT_TEAM_EMAIL="support@needatradesman.co.uk"
FRONTEND_BASE_URL=https://needatradesman.co.uk
DIGEST_SEND_HOUR_UTC=07

# Resend Webhook Secret (for verifying webhook signatures)
RESEND_WEBHOOK_SECRET=

# Cron Secret (for securing cron job endpoints)
CRON_SECRET=

# Airbnb-style Pricing Configuration
# Platform fee percentage (e.g., 1.6 for 1.6%)
PLATFORM_FEE_PCT=1.6
# Card processor fee percentage (e.g., 1.4 for 1.4%)
PROCESSOR_FEE_PCT=1.4
# Fixed processor fee in pence (e.g., 0 or 20)
PROCESSOR_FEE_FIXED_PENCE=0

# Feature Flags
# Enable Airbnb-style pricing (set to 'true' to enable)
NEXT_PUBLIC_FEATURE_AIRBNB_PRICING=false
